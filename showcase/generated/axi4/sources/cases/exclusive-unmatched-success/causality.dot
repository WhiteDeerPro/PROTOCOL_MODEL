digraph axi4_case {
  rankdir=LR;
  label="EXOKAY requires a matching completed exclusive read / EXOKAY 要求存在匹配且已完成的独占读";
  labelloc="t";
  graph [bgcolor="white", nodesep=0.4, ranksep=0.65, splines=polyline, pad=0.2];
  node [shape=box, style="rounded,filled", fillcolor="#eef5ff", color="#3169a8", fontname="sans-serif", fontsize=10];
  edge [color="#3169a8", fontname="sans-serif", fontsize=9];
  event0 [label="[0] ID6 A=0xc80 N=1 S=4B INCR"];
  event1 [label="[1] D=0x0 S=0xf L=1"];
  context [shape=note, style="filled", fillcolor="#f4f5f6", color="#7c8790", label="rejected input / 被拒输入\nID6 EXOKAY"];
  fault [shape=octagon, style="filled", fillcolor="#ffe9e7", color="#b33a2b", label="REJECTED / 已拒绝\naxi4.exclusive.unmatched_success\nEXOKAY requires a matching completed exclusive read sequence"];
  context -> fault [style=dashed, color="#777777", label="diagnostic context / 诊断上下文（非因果边）"];
}
