digraph axi4_case {
  rankdir=LR;
  label="Different write IDs may complete in reverse request order / 不同写 ID 可以按请求的逆序完成";
  labelloc="t";
  graph [bgcolor="white", nodesep=0.4, ranksep=0.65, splines=polyline, pad=0.2];
  node [shape=box, style="rounded,filled", fillcolor="#eef5ff", color="#3169a8", fontname="sans-serif", fontsize=10];
  edge [color="#3169a8", fontname="sans-serif", fontsize=9];
  event0 [label="[0] ID14 A=0xe00 N=1 S=4B INCR"];
  event1 [label="[1] ID15 A=0xe08 N=1 S=4B INCR"];
  event2 [label="[2] D=0x14 S=0xf L=1"];
  event3 [label="[3] D=0x15 S=0xf L=1"];
  event4 [label="[4] ID15 OKAY"];
  event5 [label="[5] ID14 OKAY"];
  event1 -> event4 [label="causes / 因果"];
  event3 -> event4 [label="causes / 因果"];
  event0 -> event5 [label="causes / 因果"];
  event2 -> event5 [label="causes / 因果"];
}
