{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Protocol Model: Show Version",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": ["-m", "protocol_model"],
      "options": {"cwd": "${workspaceFolder}"},
      "problemMatcher": []
    },
    {
      "label": "Protocol Model: Generate AXI4 Examples",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": ["showcase/demos/axi4/run.py"],
      "options": {"cwd": "${workspaceFolder}"},
      "problemMatcher": []
    },
    {
      "label": "Protocol Model: Render Overview PNGs",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": ["showcase/materials/assets/overview/render_png.py"],
      "options": {"cwd": "${workspaceFolder}"},
      "problemMatcher": []
    },
    {
      "label": "Protocol Model: Run Current Tests",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": ["-m", "unittest", "discover", "-s", "tests", "-v"],
      "options": {"cwd": "${workspaceFolder}"},
      "problemMatcher": [],
      "group": "test"
    }
  ]
}
