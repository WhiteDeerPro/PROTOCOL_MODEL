digraph axi4_case {
  rankdir=LR;
  label="FIXED length does not exceed sixteen transfers / FIXED 长度不超过十六拍";
  labelloc="t";
  graph [bgcolor="white", nodesep=0.4, ranksep=0.65, splines=polyline, pad=0.2];
  node [shape=box, style="rounded,filled", fillcolor="#eef5ff", color="#3169a8", fontname="sans-serif", fontsize=10];
  edge [color="#3169a8", fontname="sans-serif", fontsize=9];
  context [shape=note, style="filled", fillcolor="#f4f5f6", color="#7c8790", label="rejected input / 被拒输入\nID11 A=0x100 N=17 S=4B FIXED"];
  fault [shape=octagon, style="filled", fillcolor="#ffe9e7", color="#b33a2b", label="REJECTED / 已拒绝\naxi4.link_session.AR.event_schema\nFIXED burst length must not exceed 16 transfers"];
