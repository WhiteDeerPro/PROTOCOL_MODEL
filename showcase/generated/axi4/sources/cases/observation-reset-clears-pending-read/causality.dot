digraph axi4_case {
  rankdir=LR;
  label="Reset starts a new observation and link epoch / 复位开启新的观察与链路 epoch";
  labelloc="t";
  graph [bgcolor="white", nodesep=0.4, ranksep=0.65, splines=polyline, pad=0.2];
  node [shape=box, style="rounded,filled", fillcolor="#eef5ff", color="#3169a8", fontname="sans-serif", fontsize=10];
  edge [color="#3169a8", fontname="sans-serif", fontsize=9];
  event0 [label="[0] ID4 A=0xb00 N=1 S=4B INCR"];
  context [shape=note, style="filled", fillcolor="#f4f5f6", color="#7c8790", label="diagnostic frame / 诊断帧 · tick 3\nID4 D=0x0 OKAY L=1"];
  fault [shape=octagon, style="filled", fillcolor="#ffe9e7", color="#b33a2b", label="REJECTED / 已拒绝\naxi4.read.orphan_beat\ncompletion for key 4 has no pending obligation"];
  context -> fault [style=dashed, color="#777777", label="diagnostic context / 诊断上下文（非因果边）"];
}
