digraph axi4_case {
  rankdir=LR;
  label="A matching link-local exclusive sequence may succeed / 匹配的链路内独占序列可以成功";
  labelloc="t";
  graph [bgcolor="white", nodesep=0.4, ranksep=0.65, splines=polyline, pad=0.2];
  node [shape=box, style="rounded,filled", fillcolor="#eef5ff", color="#3169a8", fontname="sans-serif", fontsize=10];
  edge [color="#3169a8", fontname="sans-serif", fontsize=9];
  event0 [label="[0] ID5 A=0xc00 N=1 S=4B INCR"];
  event1 [label="[1] ID5 D=0x0 EXOKAY L=1"];
  event2 [label="[2] ID5 A=0xc00 N=1 S=4B INCR"];
  event3 [label="[3] D=0x0 S=0xf L=1"];
  event4 [label="[4] ID5 EXOKAY"];
  event0 -> event1 [label="causes / 因果"];
  event1 -> event2 [label="causes / 因果"];
  event2 -> event4 [label="causes / 因果"];
  event3 -> event4 [label="causes / 因果"];
}
