digraph axi4_case {
  rankdir=LR;
  label="WLAST follows the oldest AW beat count / WLAST 必须符合最早 AW 声明的拍数";
  labelloc="t";
  graph [bgcolor="white", nodesep=0.4, ranksep=0.65, splines=polyline, pad=0.2];
  node [shape=box, style="rounded,filled", fillcolor="#eef5ff", color="#3169a8", fontname="sans-serif", fontsize=10];
  edge [color="#3169a8", fontname="sans-serif", fontsize=9];
  event0 [label="[0] ID1 A=0x3 N=4 S=4B INCR"];
  context [shape=note, style="filled", fillcolor="#f4f5f6", color="#7c8790", label="diagnostic frame / 诊断帧 · tick 2\nD=0x1111111111111111 S=0x8 L=1"];
  fault [shape=octagon, style="filled", fillcolor="#ffe9e7", color="#b33a2b", label="REJECTED / 已拒绝\naxi4.write.final_marker\nW beat 1/4 requires last=False"];
  context -> fault [style=dashed, color="#777777", label="diagnostic context / 诊断上下文（非因果边）"];
}
