digraph axi4_case {
  rankdir=LR;
  label="Responses for different IDs may interleave / 不同 ID 的读响应可以交织";
  labelloc="t";
  graph [bgcolor="white", nodesep=0.4, ranksep=0.65, splines=polyline, pad=0.2];
  node [shape=box, style="rounded,filled", fillcolor="#eef5ff", color="#3169a8", fontname="sans-serif", fontsize=10];
  edge [color="#3169a8", fontname="sans-serif", fontsize=9];
  event0 [label="[0] ID1 A=0x400 N=2 S=4B INCR"];
  event1 [label="[1] ID2 A=0x500 N=2 S=4B INCR"];
  event2 [label="[2] ID1 D=0x11 OKAY L=0"];
  event3 [label="[3] ID2 D=0x21 OKAY L=0"];
  event4 [label="[4] ID1 D=0x12 OKAY L=1"];
  event5 [label="[5] ID2 D=0x22 OKAY L=1"];
  event0 -> event2 [label="causes / 因果"];
  event1 -> event3 [label="causes / 因果"];
  event2 -> event4 [label="causes / 因果"];
  event3 -> event5 [label="causes / 因果"];
}
